[Unit]
Description=Job Automation Browser Worker Service
After=network.target job-automation-orchestrator.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/automation
ExecStart=/usr/bin/node /home/ubuntu/automation/apps/browser-worker/index.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production
EnvironmentFile=/home/ubuntu/automation/.env
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=job-worker

[Install]
WantedBy=multi-user.target
