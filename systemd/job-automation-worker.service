[Unit]
Description=Job Automation Browser Worker Service
After=network.target job-automation-orchestrator.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/job-automation
ExecStart=/usr/bin/node apps/browser-worker/index.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production
EnvironmentFile=/opt/job-automation/.env
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=job-worker

[Install]
WantedBy=multi-user.target
